# ── Supabase Database ──
# Required for fetching mock operational data and persisting Zen Platform models
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_service_or_anon_key

# ── Generative AI ──
# Required to power the LangGraph orchestration and ZenDec conversational features
GEMINI_API_KEY=your_gemini_api_key

# ── Redis ──
# Required for F1-F4 Observer and Actor real-time streams
REDIS_URL=redis://localhost:6379

# ── Feature 9 (Blockchain Tracking - Optional) ──
POLYGON_PRIVATE_KEY=your_private_key
POLYGON_CONTRACT_ADDRESS=your_contract_address
POLYGON_RPC_URL=your_rpc_url
POLYGON_CHAIN_ID=80002

# ── Feature 6 (ZenDec / E-Way Bill - Optional) ──
OPENAQ_API_KEY=your_openaq_api_key
EWAYBILL_USERNAME=your_username
EWAYBILL_PASSWORD=your_password
EWAYBILL_GSTIN=your_gstin

# ── F12 / ZenRTO (Twilio / WhatsApp - Optional) ──
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
